<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ShootPorter.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="ShootPorter.App.Views.SourceBrowserView"
             x:DataType="vm:SourceBrowserViewModel">

    <DockPanel>
        <!-- Top bar: source path + browse button (Keeping it so user can actually select a folder) -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" Margin="10">
            <TextBox Text="{Binding SourcePath}" Watermark="Source folder path..." Width="500" />
            <Button Content="Scan"
                    Command="{Binding ScanCommand}"
                    IsEnabled="{Binding !IsScanning}" />
            <Button Content="Cancel"
                    Command="{Binding ScanCancelCommand}"
                    IsVisible="{Binding IsScanning}" />
        </StackPanel>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#F0F0F0" Padding="5">
            <TextBlock Text="{Binding StatusText}" />
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left pane: Dates -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="Date:" FontWeight="Bold" Margin="5"/>
                <ListBox ItemsSource="{Binding Dates}" SelectedItem="{Binding SelectedDate}" Background="Transparent" BorderThickness="0" Margin="5,0"/>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="5" Background="LightGray" ResizeDirection="Columns" />

            <!-- Main pane: Files -->
            <DataGrid Grid.Column="2"
                      ItemsSource="{Binding Files}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      HeadersVisibility="Column"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding FileName}" Width="250" />
                    <DataGridTextColumn Header="Size" Binding="{Binding SizeDisplay}" Width="100" />
                    <DataGridTextColumn Header="Date" Binding="{Binding DateDisplay}" Width="150" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                    <DataGridTextColumn Header="Download path" Binding="{Binding DownloadPath}" Width="300" />
                    <DataGridTemplateColumn Header="Source" Width="300">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding SourceFolderName}"
                                           ToolTip.Tip="{Binding FullPath}"
                                           VerticalAlignment="Center"
                                           Margin="5,0" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </DockPanel>
</UserControl>
