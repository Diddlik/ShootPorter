<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ShootPorter.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="800"
        x:Class="ShootPorter.App.Views.TokenHelpWindow"
        x:DataType="vm:TokenHelpViewModel"
        Title="Token Reference"
        Width="750" Height="800"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <Design.DataContext>
        <vm:TokenHelpViewModel/>
    </Design.DataContext>

    <Grid Margin="16" RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Token Reference" FontSize="22" FontWeight="Bold"/>
            <TextBlock Text="Use these tokens in your filename template to generate dynamic filenames" 
                       FontSize="12" Opacity="0.7" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Token Categories -->
        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Categories}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#f8fafc" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"
                                           Foreground="#2563eb"/>
                                
                                <!-- Token Grid Header -->
                                <Grid ColumnDefinitions="120,*,150" Margin="0,0,0,4">
                                    <TextBlock Grid.Column="0" Text="TOKEN" FontWeight="SemiBold" FontSize="10" Opacity="0.6"/>
                                    <TextBlock Grid.Column="1" Text="DESCRIPTION" FontWeight="SemiBold" FontSize="10" Opacity="0.6"/>
                                    <TextBlock Grid.Column="2" Text="EXAMPLE" FontWeight="SemiBold" FontSize="10" Opacity="0.6"/>
                                </Grid>
                                
                                <Rectangle Height="1" Fill="#e2e8f0" Margin="0,0,0,4"/>
                                
                                <!-- Token Items -->
                                <ItemsControl ItemsSource="{Binding Tokens}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="120,*,150" Margin="0,2">
                                                <TextBlock Grid.Column="0" 
                                                           Text="{Binding Token}" 
                                                           FontFamily="Consolas,Courier New,monospace"
                                                           FontWeight="SemiBold"
                                                           Foreground="#7c3aed"
                                                           FontSize="12"/>
                                                <TextBlock Grid.Column="1" 
                                                           Text="{Binding Description}" 
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip.Tip="{Binding Description}"/>
                                                <TextBlock Grid.Column="2" 
                                                           Text="{Binding Example}" 
                                                           FontFamily="Consolas,Courier New,monospace"
                                                           FontSize="11"
                                                           Opacity="0.7"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip.Tip="{Binding Example}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,16,0,0">
            <TextBlock Text="Tip: Tokens can be combined, e.g. {Y}{m}{D}_{H}{M}{S}_{T8}" 
                       FontSize="11" Opacity="0.6" VerticalAlignment="Center"
                       FontStyle="Italic"/>
            <Button Grid.Column="1" Content="Close" Padding="24,8" Click="CloseButton_Click"/>
        </Grid>
    </Grid>
</Window>
