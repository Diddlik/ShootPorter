<suki:SukiWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ShootPorter.App.ViewModels"
        xmlns:suki="using:SukiUI.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="ShootPorter.App.Views.UpdateDialog"
        x:DataType="vm:UpdateViewModel"
        Title="Update Available"
        Width="460" Height="280"
        CanMinimize="False" CanResize="False">

    <StackPanel Margin="24" Spacing="16">
        <TextBlock Text="Update Available" FontSize="20" FontWeight="SemiBold"/>

        <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" Opacity="0.8"/>

        <ProgressBar Value="{Binding DownloadProgress}" Maximum="100"
                     IsVisible="{Binding IsDownloading}" Height="8"/>

        <TextBlock Text="{Binding ErrorMessage}" Foreground="#ef4444"
                   TextWrapping="Wrap" IsVisible="{Binding HasError}"/>

        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
            <!-- Pre-download state -->
            <Button Content="Skip" Classes="Flat"
                    Command="{Binding SkipUpdateCommand}"
                    IsVisible="{Binding ShowPromptButtons}"/>
            <Button Content="Download Now" Classes="Flat Accent"
                    Command="{Binding DownloadUpdateCommand}"
                    IsVisible="{Binding ShowPromptButtons}"/>

            <!-- Downloading state -->
            <Button Content="Cancel" Classes="Flat"
                    Command="{Binding SkipUpdateCommand}"
                    IsVisible="{Binding IsDownloading}"/>

            <!-- Post-download state -->
            <Button Content="Install on Exit" Classes="Flat"
                    Command="{Binding InstallOnExitCommand}"
                    IsVisible="{Binding IsReadyToInstall}"/>
            <Button Content="Restart Now" Classes="Flat Accent"
                    Command="{Binding InstallAndRestartCommand}"
                    IsVisible="{Binding IsReadyToInstall}"/>
        </StackPanel>
    </StackPanel>
</suki:SukiWindow>
