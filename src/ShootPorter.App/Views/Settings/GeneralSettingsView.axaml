<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ShootPorter.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:suki="using:SukiUI.Controls"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="500"
             x:Class="ShootPorter.App.Views.Settings.GeneralSettingsView"
             x:DataType="vm:SettingsViewModel">

    <StackPanel Spacing="16">
        <StackPanel>
            <TextBlock Text="General Preferences" FontSize="20" FontWeight="SemiBold"/>
            <TextBlock Text="Device connection and file handling rules." Opacity="0.6" FontSize="13"/>
        </StackPanel>

        <suki:GlassCard>
            <StackPanel Spacing="12">
                <TextBlock Text="Application" FontWeight="SemiBold" FontSize="14"/>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <ToggleSwitch IsChecked="{Binding CheckForUpdates}" OnContent="" OffContent=""/>
                    <TextBlock Text="Check for updates on startup" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </suki:GlassCard>

        <suki:GlassCard>
            <StackPanel Spacing="12">
                <TextBlock Text="Image Source" FontWeight="SemiBold" FontSize="14"/>
                <RadioButton Content="Auto-detect camera or card reader" IsChecked="{Binding IsAutoDetect}" GroupName="ImageSource"/>
                <RadioButton Content="Camera (USB connected)" IsChecked="{Binding IsCameraUsb}" GroupName="ImageSource"/>
                <RadioButton Content="Card reader or external storage" IsChecked="{Binding IsCardReader}" GroupName="ImageSource"/>
            </StackPanel>
        </suki:GlassCard>
        
        <suki:GlassCard>
            <StackPanel Spacing="12">
                <TextBlock Text="File Handling" FontWeight="SemiBold" FontSize="14"/>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <ToggleSwitch IsChecked="{Binding UseCaptureTime}" OnContent="" OffContent=""/>
                    <TextBlock Text="Use capture time for file timestamp" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <ToggleSwitch IsChecked="{Binding AutoRotateJpegs}" OnContent="" OffContent=""/>
                    <TextBlock Text="Auto-rotate JPEGs (lossless)" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <ToggleSwitch IsChecked="{Binding ConvertToLowerCase}" OnContent="" OffContent=""/>
                    <TextBlock Text="Convert filename to lower case" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </suki:GlassCard>
    </StackPanel>
</UserControl>
