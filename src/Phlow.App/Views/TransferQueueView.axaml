<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Phlow.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:suki="using:SukiUI.Controls"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="800"
             x:Class="Phlow.App.Views.TransferQueueView"
             x:DataType="vm:TransferQueueViewModel">

    <Grid RowDefinitions="Auto,Auto,Auto,*">
        <!-- Overall Progress Card - Compact -->
        <suki:GlassCard Grid.Row="0" Margin="0,0,0,12">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="24">
                    <StackPanel>
                        <TextBlock Text="Overall Progress" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock FontSize="11" Opacity="0.6" FontFamily="Consolas,Courier New,monospace"
                                   Text="{Binding DestinationPath, StringFormat='→ {0}'}"/>
                    </StackPanel>
                    <ProgressBar Value="{Binding OverallProgressPercent}" Maximum="100" 
                                 Width="200" Height="8"
                                 VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <TextBlock Text="{Binding OverallProgressPercent, StringFormat='{}{0}%'}" 
                               FontSize="18" FontWeight="Bold" Classes="Accent"/>
                    <TextBlock Opacity="0.6" FontSize="12" VerticalAlignment="Center">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0}/{1}">
                                <Binding Path="CompletedFiles"/>
                                <Binding Path="TotalFiles"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock Text="{Binding DownloadSpeedText}" FontSize="12" 
                               FontFamily="Consolas,Courier New,monospace"
                               Opacity="0.7" VerticalAlignment="Center"
                               IsVisible="{Binding IsDownloadActive}"/>
                    <TextBlock Text="{Binding EstimatedTimeRemainingText}" FontSize="12" 
                               Opacity="0.7" VerticalAlignment="Center"
                               IsVisible="{Binding IsDownloadActive}"/>
                </StackPanel>
            </Grid>
        </suki:GlassCard>

        <!-- Date Selection + Stats Row - Compact -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
            <!-- Date Cards -->
            <suki:GlassCard>
                <Grid RowDefinitions="Auto,Auto">
                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,8">
                        <PathIcon Data="{StaticResource IconCalendar}" Width="14" Height="14"/>
                        <TextBlock Text="Select by Date" FontWeight="SemiBold" FontSize="12"/>
                        <Button Content="All" Command="{Binding SelectAllDatesCommand}"
                                Classes="Flat" FontSize="10" Padding="8,4"/>
                        <Button Content="None" Command="{Binding DeselectAllDatesCommand}"
                                Classes="Flat" FontSize="10" Padding="8,4"/>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding DateGroups}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding ToggleCommand}" 
                                            Classes="Flat" Padding="10,6" MinWidth="70">
                                        <StackPanel Spacing="0" HorizontalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                                <CheckBox IsChecked="{Binding IsSelected}" MinWidth="0" Padding="0"/>
                                                <TextBlock Text="{Binding DisplayDate}" FontWeight="SemiBold" FontSize="11"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding FileCount, StringFormat='{}{0}'}" 
                                                       FontSize="9" HorizontalAlignment="Center" Opacity="0.6"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </suki:GlassCard>
            
            <!-- Summary Stats - Compact -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="12,0,0,0">
                <suki:GlassCard Padding="12,8" MinWidth="80">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Total" FontSize="10" Opacity="0.6" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalFiles}" FontSize="20" FontWeight="Bold" 
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </suki:GlassCard>
                <suki:GlassCard Padding="12,8" MinWidth="80">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Ready" FontSize="10" Opacity="0.6" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ReadyToTransfer}" FontSize="20" FontWeight="Bold" 
                                   Foreground="#10b981" HorizontalAlignment="Center"/>
                    </StackPanel>
                </suki:GlassCard>
                <suki:GlassCard Padding="12,8" MinWidth="80">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Clashes" FontSize="10" Foreground="#f59e0b" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding NameClashes}" FontSize="20" FontWeight="Bold" 
                                   Foreground="#f59e0b" HorizontalAlignment="Center"/>
                    </StackPanel>
                </suki:GlassCard>
            </StackPanel>
        </Grid>

        <!-- Search Bar - Compact -->
        <suki:GlassCard Grid.Row="2" Margin="0,0,0,12">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <PathIcon Data="{StaticResource IconSearch}" Width="12" Height="12" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding SearchText}" Watermark="Search files..." 
                             Width="200" FontSize="12"/>
                </StackPanel>
                
                <ScrollViewer Grid.Column="2"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding FilterChips}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="6"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:TransferFilterChip">
                                <Button Command="{Binding SelectCommand}"
                                        Padding="10,5"
                                        MinHeight="28"
                                        Background="{Binding Background}"
                                        BorderBrush="{Binding BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        ToolTip.Tip="{Binding Label}">
                                    <TextBlock Text="{Binding DisplayText}"
                                               Foreground="{Binding Foreground}"
                                               FontSize="11"
                                               FontWeight="SemiBold"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </suki:GlassCard>

        <!-- File Table - Takes remaining space -->
        <suki:GlassCard Grid.Row="3" Padding="0,8,0,0">
            <DataGrid ItemsSource="{Binding Files}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      HeadersVisibility="Column"
                      BorderThickness="0"
                      x:Name="FilesDataGrid"
                      DoubleTapped="FilesDataGrid_DoubleTapped">
                <DataGrid.Styles>
                    <Style Selector="DataGridColumnHeader">
                        <Setter Property="Background" Value="#182233"/>
                        <Setter Property="Foreground" Value="#e5edf8"/>
                        <Setter Property="BorderBrush" Value="#2c384b"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="MinHeight" Value="34"/>
                        <Setter Property="Padding" Value="8,0"/>
                    </Style>
                </DataGrid.Styles>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="☑" Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected}" 
                                          HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    
                    <DataGridTemplateColumn Header="File Name" Width="1.1*" MinWidth="140" MaxWidth="230">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="6,0">
                                    <PathIcon Data="{StaticResource IconImage}" Width="12" Height="12"/>
                                    <TextBlock Text="{Binding FileName}" VerticalAlignment="Center" FontSize="12"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    
                    <DataGridTemplateColumn Header="Status" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Padding="6,3" 
                                        HorizontalAlignment="Left"
                                        Background="{Binding StatusBackground}"
                                        BorderBrush="{Binding StatusBorder}"
                                        BorderThickness="1">
                                    <TextBlock Text="{Binding StatusText}" FontSize="10"
                                               Foreground="{Binding StatusForeground}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    
                    <DataGridTemplateColumn Header="Size" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding SizeDisplay}" FontSize="12" 
                                           VerticalAlignment="Center" Margin="6,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    
                    <DataGridTemplateColumn Header="Date" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Margin="6,0">
                                    <TextBlock Text="{Binding CaptureDateDisplay}" FontSize="11"/>
                                    <TextBlock Text="{Binding CaptureTimeDisplay}" FontSize="9" Opacity="0.5"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    
                    <DataGridTemplateColumn Header="Download Path" Width="2.2*" MinWidth="240">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DestinationPreview}" 
                                           ToolTip.Tip="{Binding DestinationPreview}"
                                           FontFamily="Consolas,Courier New,monospace"
                                           FontSize="11" Margin="6,0"
                                           TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    
                    <DataGridTemplateColumn Header="Source Path" Width="1.7*" MinWidth="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding SourcePath}" 
                                           ToolTip.Tip="{Binding SourcePath}"
                                           FontSize="11" Margin="6,0"
                                           TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </suki:GlassCard>
    </Grid>
</UserControl>
